{
  "private": true,
  "type": "module",
  "name": "watch-duty-manager",
  "description": "",
  "license": "",
  "scripts": {
    "build": "react-router build",
    "commit": "cz",
    "dev": "node -r dotenv/config node_modules/.bin/react-router dev --host 0.0.0.0",
    "db:setup": "npx prisma db push && npx prisma db seed",
    "format": "prettier --write \"./app/**/*.{ts,tsx,js,json}\"",
    "lint": "eslint \"app/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"app/**/*.{ts,tsx}\" --fix",
    "start": "react-router-serve ./build/server/index.js",
    "test": "SECRET=test-secret vitest run",
    "test:tsc": "react-router typegen && tsc --noEmit --incremental",
    "test:tsc:watch": "tsc --noEmit --watch --incremental"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@react-router/node": "^7.0.0",
    "@react-router/serve": "^7.0.0",
    "dotenv": "^17.2.3",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.6.0",
    "fp-ts": "^2.16.11",
    "isbot": "^5.1.32",
    "prisma": "^6.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-multi-date-picker": "^4.5.2",
    "react-router": "^7.0.0",
    "react-use": "^17.6.0",
    "recharts": "^2.15.3",
    "temporal-polyfill": "^0.3.0",
    "url-from": "^1.0.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.0.0",
    "@react-router/fs-routes": "^7.15.1",
    "@tailwindcss/vite": "^4.1.18",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.19.7",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild-register": "^3.6.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "lint-staged": "^16.2.7",
    "prettier": "3.6.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^6.4.1",
    "vite-plugin-cjs-interop": "^2.4.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=22"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "sideEffects": false,
  "volta": {
    "node": "22.12.0",
    "npm": "11.4.2"
  }
}
